# Development Dockerfile with hot-reload support
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY pyproject.toml ./

# Install PyTorch CPU-only version
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Install Python dependencies + dev tools
RUN pip install --no-cache-dir . && \
    pip install --no-cache-dir watchdog

# Download Argos Translate models (will be cached in volume)
COPY download_models.py ./
RUN python download_models.py

# Source code will be mounted as volume

# Set Python path
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

# Default command runs worker (no auto-reload by default)
# Use compose.dev.yml for watchdog-based reload
CMD ["python", "-m", "src.main"]
